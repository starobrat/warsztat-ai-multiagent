# Skopiuj ten plik do .env i uzupełnij klucz:
#   cp .env.example .env
#
# Klucz OpenRouter zdobędziesz na https://openrouter.ai/keys
# Jeden klucz obsługuje całe szkolenie (część 1 i część 2 / ADK).

OPENROUTER_API_KEY=

# Model używany w całym szkoleniu (id modelu w OpenRouter, bez prefiksu litellm).
# Domyślnie tani i bardzo dobry w function callingu. Możesz zmienić na dowolny
# model z https://openrouter.ai/models (np. anthropic/claude-3.5-sonnet).
OPENROUTER_MODEL=openai/gpt-4o-mini
