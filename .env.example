# Skopiuj ten plik do .env i uzupełnij klucz:
#   cp .env.example .env
#
# Klucz OpenAI zdobędziesz na https://platform.openai.com/api-keys
# Jeden klucz obsługuje całe szkolenie (część 1 i część 2 / ADK).

OPENAI_API_KEY=

# Model używany w całym szkoleniu.
OPENAI_MODEL=gpt-5.4-mini

# Słabszy model - tylko ćwiczenie 8 (tuning promptu / TDD). Na mocnym modelu
# słaby prompt nie oblewa evalu (model i tak odpowiada dobrze), więc nie da się
# pokazać pętli czerwony->zielony. Słabszy model jest wrażliwy na jakość promptu.
OPENAI_MODEL_WEAK=gpt-4o-mini
